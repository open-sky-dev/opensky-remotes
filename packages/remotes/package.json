{
	"author": "notnotjake",
	"name": "@opensky/remotes",
	"description": "SvelteKit remotes helper utilities",
	"version": "0.0.3",
	"repository": {
		"directory": "packages/remotes",
		"type": "git",
		"url": "git+https://github.com/open-sky-dev/opensky-remotes.git"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@sveltejs/kit": ">=2.57.1 <3",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.38.0",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/package": "^2.5.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/node": "^25.6.0",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.5",
		"globals": "^16.4.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"publint": "^0.3.15",
		"svelte": "^5.41.1",
		"svelte-check": "^4.3.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.2",
		"vite": "^7.1.11"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"keywords": [
		"svelte",
		"sveltekit",
		"remote-functions",
		"forms",
		"validation",
		"utility"
	],
	"svelte": "./dist/index.js",
	"type": "module",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"prepack": "bun run build",
		"prepare": "svelte-kit sync || echo ''"
	}
}
