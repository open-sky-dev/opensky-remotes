{
	"name": "@opensky/remotes",
	"scripts": {
		"check": "svelte-kit sync && tsc --noEmit --project ./tsconfig.json",
		"format": "oxfmt .",
		"lint": "oxfmt --check . && eslint .",
		"dev": "bun run build && bun link",
		"build": "svelte-kit sync && svelte-package && publint",
		"prepack": "bun run build",
		"prepare": "svelte-kit sync || echo ''"
	},
	"description": "SvelteKit remotes helper utilities",
	"author": "notnotjake",
	"version": "0.1.0",
	"repository": {
		"directory": "packages/remotes",
		"type": "git",
		"url": "git+https://github.com/open-sky-dev/opensky-remotes.git"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"@sveltejs/kit": ">=2.68.0 <3",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"eslint": "^10.6.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"oxfmt": "^0.57.0",
		"publint": "^0.3.21",
		"svelte": "^5.56.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.3"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"keywords": [
		"svelte",
		"sveltekit",
		"remote-functions",
		"forms",
		"validation",
		"utility"
	],
	"svelte": "./dist/index.js",
	"type": "module",
	"types": "./dist/index.d.ts"
}
