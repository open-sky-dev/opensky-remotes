{
	"author": "notnotjake",
	"name": "@opensky/remotes",
	"description": "SvelteKit remotes helper utilities",
	"version": "0.0.2",
	"repository": {
		"directory": "packages/seo",
		"type": "git",
		"url": "https://github.com/open-sky-dev/opensky-remotes.git"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"runed": "^0.35.1"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.27.0",
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.38.0",
		"@sveltejs/adapter-auto": "^6.1.1",
		"@sveltejs/kit": "^2.47.2",
		"@sveltejs/package": "^2.5.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.5",
		"globals": "^16.4.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"publint": "^0.3.15",
		"svelte": "^5.41.1",
		"svelte-check": "^4.3.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.2",
		"vite": "^7.1.11"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"keywords": [
		"svelte",
		"sveltekit",
		"metadata",
		"seo",
		"utility",
		"meta-tags",
		"open-graph",
		"head",
		"svelte-meta",
		"svelte-seo"
	],
	"private": false,
	"scripts": {
		"build": "vite build && npm run prepack",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview"
	},
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"type": "module",
	"types": "./dist/index.d.ts"
}
